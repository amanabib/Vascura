# Copy this file to ".env" and fill in your real key.
# NEVER commit your real .env file to git or share it publicly.

# Required ONLY for live Claude advice. Without it, the app still works and
# shows static, source-backed advice instead. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional. Which Claude model the advice layer uses. Defaults to a sensible
# current model if left blank. Cheaper models (e.g. a Haiku model) cost less.
# Verify current model names at https://docs.claude.com
# ADVICE_MODEL=claude-sonnet-4-6

# Optional. Port the local server listens on. Defaults to 5000.
# PORT=5000
